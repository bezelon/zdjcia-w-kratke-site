---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Get all posts and sort by date descending
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Helper function to format dates
function formatDate(dateString: string | Date) {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---

<Layout title="Our Botanical Blog" description="Read our latest stories, soapmaking guides, and botanical skin care tips.">
  <section class="section blog-header-section">
    <div class="container text-center">
      <span class="blog-subtitle">Stories & Guides</span>
      <h1 class="blog-title">The Botanical Journal</h1>
      <p class="blog-desc">
        Explore articles on natural skincare, the traditional cold-process soapmaking method, and the benefits of organic essential oils.
      </p>
    </div>
  </section>

  <section class="section blog-grid-section">
    <div class="container">
      {sortedPosts.length === 0 ? (
        <div class="no-posts">
          <p>No blog posts found. Check back later or create one in Sveltia CMS!</p>
        </div>
      ) : (
        <div class="blog-grid">
          {sortedPosts.map(post => (
            <article class="blog-card">
              <a href={`/blog/${post.id}`} class="blog-image-link">
                <div class="image-wrapper">
                  <img src={post.data.image || "/images/uploads/lavender-soap.png"} alt={post.data.title} class="blog-image" />
                </div>
              </a>
              
              <div class="blog-content">
                <span class="blog-date">{formatDate(post.data.date)}</span>
                <a href={`/blog/${post.id}`}>
                  <h3 class="blog-post-title">{post.data.title}</h3>
                </a>
                <p class="blog-excerpt">{post.data.excerpt}</p>
                <a href={`/blog/${post.id}`} class="read-more">
                  Read Article
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-header-section {
    background-color: var(--bg-secondary);
    padding: 5rem 0 4rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .text-center {
    text-align: center;
  }

  .blog-subtitle {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-sage);
    font-weight: 600;
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .blog-title {
    font-size: 3rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .blog-desc {
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .blog-grid-section {
    background-color: var(--bg-primary);
    padding: 4rem 0;
  }

  .no-posts {
    text-align: center;
    padding: 3rem;
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 3rem;
  }

  .blog-card {
    background-color: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: var(--transition-bounce);
  }

  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.04);
    border-color: var(--color-sage);
  }

  .blog-image-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .image-wrapper {
    position: relative;
    padding-top: 56.25%; /* 16:9 Aspect Ratio */
    background-color: var(--bg-secondary);
    overflow: hidden;
  }

  .blog-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .blog-card:hover .blog-image {
    transform: scale(1.05);
  }

  .blog-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-date {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .blog-post-title {
    font-size: 1.4rem;
    color: var(--text-primary);
    margin-bottom: 0.8rem;
    font-weight: 600;
    line-height: 1.3;
    transition: var(--transition-smooth);
  }

  .blog-post-title:hover {
    color: var(--color-sage);
  }

  .blog-excerpt {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 1.5rem;
    flex: 1;
    font-weight: 300;
  }

  .read-more {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--text-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
  }

  .read-more:hover {
    color: var(--color-sage);
  }

  .read-more hover svg {
    transform: translateX(3px);
  }
</style>
