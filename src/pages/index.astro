---
import Layout from '../layouts/Layout.astro';
import SoapHero from '../components/SoapHero.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

// Get all products and sort/filter to get top 3 available ones as featured
const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.available).slice(0, 3);

// Get all blog posts and get the top 3 latest
const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title="Pure, Botanical Cold-Process Soaps">
  <!-- Hero Section -->
  <SoapHero />
  
  <!-- Featured Products Section -->
  <section class="section featured-section">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Our Curated Collection</span>
        <h2 class="section-title">Featured Botanicals</h2>
        <p class="section-desc">Each bar is hand-cut and cured for 6 weeks, resulting in a gentle, long-lasting soap.</p>
      </div>
      
      <div class="product-grid">
        {featuredProducts.map(product => (
          <ProductCard
            title={product.data.title}
            price={product.data.price}
            image={product.data.image}
            description={product.data.description}
            slug={product.id}
            available={product.data.available}
          />
        ))}
      </div>
      
      <div class="view-all-wrapper">
        <a href="/products" class="btn btn-secondary">Explore All Products</a>
      </div>
    </div>
  </section>

  <!-- Brand Story Section -->
  <section id="our-story" class="section story-section">
    <div class="container story-container">
      <div class="story-image-group">
        <img src="/images/uploads/calendula-soap.png" alt="Handmade Natural Soaps drying in studio" class="story-image img-1" />
        <div class="story-blob"></div>
      </div>
      
      <div class="story-content">
        <span class="story-subtitle">The Soapmaker's Art</span>
        <h2 class="story-title">Crafted in Harmony with Nature</h2>
        <p class="story-text">
          Earth & Lather was born from a desire to return to pure, simple, and skin-loving bath rituals. We believe that what you put on your body is just as important as what you put in it.
        </p>
        <p class="story-text">
          Using the traditional cold-process soapmaking method, we combine nourishing plant-based oils (like organic olive and coconut oils) and butter (shea and cocoa) with distilled botanicals and clays. Our soaps cure naturally for six weeks, preserving the moisture-rich natural glycerin that commercial soaps strip away.
        </p>
        <div class="story-features">
          <div class="feature-item">
            <span class="feature-icon">🌿</span>
            <div>
              <h5>Pure Essential Oils</h5>
              <p>Scented exclusively with therapeutic-grade botanical oils.</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-icon">🐰</span>
            <div>
              <h5>Cruelty-Free & Vegan</h5>
              <p>We never use animal fats, palm oils, or test on animals.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts Section -->
  <section class="section blog-section">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Stories & Recipes</span>
        <h2 class="section-title">The Botanical Journal</h2>
        <p class="section-desc">Insights into slow bathing rituals, natural skincare benefits, and traditional soapmaking.</p>
      </div>

      {latestPosts.length === 0 ? (
        <p class="text-center" style="color: var(--text-secondary); text-align: center;">No articles found. Add one in Sveltia CMS!</p>
      ) : (
        <div class="blog-grid">
          {latestPosts.map(post => (
            <article class="blog-card">
              <a href={`/blog/${post.id}`} class="blog-img-link">
                <div class="blog-img-wrapper">
                  <img src={post.data.image || "/images/uploads/lavender-soap.png"} alt={post.data.title} />
                </div>
              </a>
              <div class="blog-card-content">
                <span class="blog-card-date">{new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                <a href={`/blog/${post.id}`}>
                  <h3 class="blog-card-title">{post.data.title}</h3>
                </a>
                <p class="blog-card-desc">{post.data.excerpt}</p>
                <a href={`/blog/${post.id}`} class="read-more-link">Read Story &rarr;</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  /* Section Headers */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-subtitle {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .section-title {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-desc {
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-secondary);
  }

  /* Grid Layout */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .view-all-wrapper {
    text-align: center;
  }

  /* Story Section */
  .story-section {
    background-color: var(--bg-secondary);
  }

  .story-container {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .story-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .story-image-group {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .story-image {
    width: 100%;
    max-width: 380px;
    border-radius: 20px;
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);
    z-index: 2;
  }

  .story-blob {
    position: absolute;
    width: 95%;
    height: 95%;
    background-color: var(--bg-tertiary);
    border-radius: 50% 60% 40% 70%;
    z-index: 1;
    transform: rotate(15deg);
  }

  .story-content {
    display: flex;
    flex-direction: column;
  }

  .story-subtitle {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-sage);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .story-title {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .story-text {
    color: var(--text-secondary);
    margin-bottom: 1.2rem;
    font-size: 1rem;
  }

  .story-features {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .feature-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .feature-icon {
    font-size: 1.8rem;
    line-height: 1;
    background-color: var(--bg-primary);
    padding: 0.5rem;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
  }

  .feature-item h5 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .feature-item p {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  /* Latest Blog Section Styling */
  .blog-section {
    background-color: var(--bg-primary);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }

  .blog-card {
    background-color: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: var(--transition-bounce);
  }

  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.03);
    border-color: var(--color-sage);
  }

  .blog-img-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .blog-img-wrapper {
    position: relative;
    padding-top: 56.25%; /* 16:9 Aspect Ratio */
    background-color: var(--bg-secondary);
  }

  .blog-img-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .blog-card:hover .blog-img-wrapper img {
    transform: scale(1.05);
  }

  .blog-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-date {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .blog-card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.6rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .blog-card-title:hover {
    color: var(--color-sage);
  }

  .blog-card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 1.2rem;
    flex: 1;
    font-weight: 300;
  }

  .read-more-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--text-primary);
    transition: var(--transition-smooth);
  }

  .read-more-link:hover {
    color: var(--color-sage);
    padding-left: 3px;
  }
</style>
