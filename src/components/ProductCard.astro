---
interface Props {
  title: string;
  price: number;
  image?: string;
  description: string;
  slug: string;
  available?: boolean;
}

const { title, price, image = "/images/uploads/lavender-soap.png", description, slug, available = true } = Astro.props;

// Format price in GBP (£)
const formattedPrice = `£${price.toFixed(2)}`;
---

<article class="card">
  <a href={`/products/${slug}`} class="card-image-link">
    <div class="image-container">
      <img src={image} alt={title} class="product-image" />
      {!available && <span class="badge sold-out">Sold Out</span>}
      {available && price >= 6.0 && <span class="badge premium">Premium</span>}
    </div>
  </a>
  
  <div class="card-content">
    <a href={`/products/${slug}`} class="title-link">
      <h3 class="product-title">{title}</h3>
    </a>
    <p class="product-desc">{description}</p>
    
    <div class="card-footer">
      <span class="product-price">{formattedPrice}</span>
      <a href={`/products/${slug}`} class="btn btn-card-details">
        {available ? "View Details" : "Read Details"}
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    background-color: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: var(--transition-bounce);
    height: 100%;
  }

  .card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.05);
    border-color: var(--color-accent);
  }

  .card-image-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .image-container {
    position: relative;
    padding-top: 100%; /* 1:1 Square aspect ratio */
    background-color: var(--bg-secondary);
    overflow: hidden;
  }

  .product-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .card:hover .product-image {
    transform: scale(1.06);
  }

  .badge {
    position: absolute;
    top: 15px;
    right: 15px;
    padding: 0.35rem 0.8rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sold-out {
    background-color: var(--text-secondary);
    color: var(--text-light);
  }

  .premium {
    background-color: var(--color-gold);
    color: var(--text-primary);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .title-link {
    color: var(--text-primary);
  }

  .title-link:hover {
    color: var(--color-accent);
  }

  .product-title {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .product-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    font-weight: 300;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
    margin-top: auto;
  }

  .product-price {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .btn-card-details {
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.05em;
    border: 1px solid var(--border-color);
    background-color: transparent;
    color: var(--text-primary);
    transition: var(--transition-smooth);
  }

  .btn-card-details:hover {
    background-color: var(--color-accent);
    color: var(--text-light);
    border-color: var(--color-accent);
  }
</style>
